# Options Tycoon — Required Environment Variables
# Copy this to .env for local development, or set in Railway dashboard for production.

# --- Required ---
DATABASE_URL=postgresql://user:password@host:5432/options_tycoon
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Optional (defaults shown) ---
ALLOWED_ORIGINS=https://web-production-ddf13.up.railway.app,http://localhost:8000
PRODUCTION=false
RAILWAY_ENVIRONMENT=

# --- Notes ---
# GOOGLE_CLIENT_ID: Get from Google Cloud Console > APIs & Services > Credentials
# DATABASE_URL: Provided automatically by Railway PostgreSQL addon
# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins
# PRODUCTION: Set to "true" on Railway to disable Swagger docs
