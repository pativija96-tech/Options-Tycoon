# ============================================
# Options Tycoon — Git Ignore Rules
# ============================================

# --- Database (each user creates their own on first launch) ---
options_tycoon.db
options_tycoon.db-wal
options_tycoon.db-shm

# --- Personal telemetry & runtime data ---
feedback_loop.json
friend_report.json

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Test cache ---
.pytest_cache/
htmlcov/
.coverage

# --- Backups (personal) ---
backups/*.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS junk ---
Thumbs.db
.DS_Store
desktop.ini

# --- Environment variables (actual secrets, NEVER commit) ---
.env

# --- Live Signal Engine: credentials (NEVER commit) ---
config/kite_creds.json
config/telegram.json

# --- Output: runtime-generated signals, logs, trade data ---
output/

# --- Historical data: downloaded/generated at runtime ---
data/historical/

# --- Virtual environments ---
venv/
.venv/
env/
